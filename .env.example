# === Database ===
POSTGRES_USER=ondoc_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ondoc_db

# === Redis ===
# REDIS_URL is auto-built in docker-compose per service

# === Telegram ===
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_RANDOM_SECRET
TELEGRAM_WEBHOOK_BASE_URL=https://24ondoc.ru

# === Chatwoot ===
CHATWOOT_SECRET_KEY_BASE=CHANGE_ME_RAILS_SECRET
CHATWOOT_FRONTEND_URL=https://chat.24ondoc.ru
CHATWOOT_API_KEY=CHANGE_ME_CHATWOOT_API_TOKEN
CHATWOOT_BASE_URL=http://chatwoot:3000
CHATWOOT_SUPPORT_ACCOUNT_ID=2
CHATWOOT_WEBHOOK_TOKEN=<secret>
CHATWOOT_PLATFORM_API_KEY=<platform_app_token>

# === OpenRouter (AI Analysis) ===
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_KEY

# === OpenAI (Whisper fallback) ===
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY

# === T2 ATS ===
T2_WEBHOOK_SECRET=CHANGE_ME_T2_SECRET

# === MinIO (Voice Samples Storage) ===
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000

# === Whisper (self-hosted, optional) ===
WHISPER_BASE_URL=http://whisper:9000

# === Chatwoot SMTP ===
MAILER_SENDER_EMAIL=noreply@24ondoc.ru
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587

# === Admin Panel ===
ADMIN_JWT_SECRET=CHANGE_ME_RANDOM_SECRET
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
TELEGRAM_BOT_USERNAME=

# === App ===
LOG_LEVEL=INFO
