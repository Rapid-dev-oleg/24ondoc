# === Staging Environment ===
# Копия .env.example с безопасными значениями для staging/E2E тестирования.
# НЕ используйте production-токены и ключи!
#
# Использование:
#   cp .env.staging.example .env.staging
#   # заполните обязательные поля (TELEGRAM_BOT_TOKEN для тестового бота)
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d

# === Database (staging) ===
POSTGRES_USER=staging_user
POSTGRES_PASSWORD=staging_password_change_me
POSTGRES_DB=ondoc_staging

# === Telegram (тестовый бот — создайте через @BotFather) ===
TELEGRAM_BOT_TOKEN=STAGING_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_WEBHOOK_SECRET=staging-webhook-secret
TELEGRAM_WEBHOOK_BASE_URL=http://localhost:8100
TELEGRAM_BOT_USERNAME=

# === Chatwoot (staging instance на порту 3100) ===
CHATWOOT_SECRET_KEY_BASE=staging-secret-key-base-change-me-to-random-64-chars
CHATWOOT_FRONTEND_URL=http://localhost:3100
CHATWOOT_API_KEY=STAGING_CHATWOOT_API_KEY
CHATWOOT_BASE_URL=http://chatwoot-staging:3000
CHATWOOT_SUPPORT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_TOKEN=staging-chatwoot-webhook-token
CHATWOOT_PLATFORM_API_KEY=
CHATWOOT_INBOX_ID=1
CHATWOOT_ACCOUNT_ID=1

# === OpenRouter (AI Analysis) ===
# Можно использовать тот же ключ или отдельный с лимитом
OPENROUTER_API_KEY=STAGING_OPENROUTER_KEY

# === OpenAI (Whisper fallback, опционально) ===
OPENAI_API_KEY=

# === T2 ATS (staging) ===
T2_WEBHOOK_SECRET=staging-t2-secret

# === MinIO (staging, порт 9100/9101) ===
MINIO_ACCESS_KEY=staging_minio_user
MINIO_SECRET_KEY=staging_minio_password
MINIO_ENDPOINT=minio-staging:9000

# === Whisper (self-hosted, опционально) ===
WHISPER_BASE_URL=http://whisper:9000

# === Admin Panel (staging) ===
ADMIN_JWT_SECRET=staging-admin-jwt-secret
ADMIN_PASSWORD=staging-admin-password

# === App ===
LOG_LEVEL=DEBUG
